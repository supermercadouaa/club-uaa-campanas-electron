{
  "name": "club-uaa-campanas-electron",
  "version": "3.0.3",
  "description": "Electron campaign manager for Club UAA",
  "main": "./dist/main/main.js",
  "homepage": "./",
  "author": "Club UAA",
  "license": "MIT",
  "scripts": {
    "vite": "vite --port 3000",
    "tsc": "tsc src/main/**/*.ts --outDir dist --module commonjs",
    "electron": "electron .",
    "build": "tsc -p . --skipLibCheck && vite build",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.6.0",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tedious": "^16.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.23.1",
    "png-to-ico": "^3.0.2",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  }
}
