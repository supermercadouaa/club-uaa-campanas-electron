{
  "appId": "com.clubuaa.campanas",
  "productName": "Club UAA Campañas",
  "directories": {
    "buildResources": "assets",
    "output": "dist-app"
  },
  "files": [
    "dist/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/icon.ico"
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "allowToChangeInstallationDirectory": false,
    "deleteAppDataOnUninstall": false
  },
  "publish": {
    "provider": "github",
    "owner": "supermercadouaa",
    "repo": "club-uaa-campanas-electron",
    "releaseType": "release"
  }
}
